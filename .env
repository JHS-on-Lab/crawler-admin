# ================================================================
# 공통 기본값 — 민감 정보 없음, 이미지에 포함됨
# ================================================================

APP_ENV=local

# Web
PORT=8000

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily

# SSH Tunnel (기본 비활성)
TUNNEL_ENABLED=false
TUNNEL_SSH_PORT=22
TUNNEL_SSH_USER=ubuntu
TUNNEL_LOCAL_PORT=13306

# RDS 기본 포트
RDS_PORT=3306
RDS_CRAWLER_DB=keyword_crawler

# 세션 (운영 환경에서는 반드시 override)
SESSION_SECRET=change-me-in-production
