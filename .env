# ================================================================
# 공통 기본값 — 민감 정보 없음, 이미지에 포함됨
# ================================================================

APP_ENV=local

# Web
PORT=8000

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
LOG_RETAIN_DAYS=30    # daily 모드: 며칠치 보관 (기본 30)
LOG_BACKUP_COUNT=10   # size 모드: 파일 몇 개 보관 (기본 10)

# SSH Tunnel (기본 비활성)
TUNNEL_ENABLED=false
TUNNEL_SSH_PORT=22
TUNNEL_SSH_USER=ubuntu
TUNNEL_LOCAL_PORT=13306

# RDS 기본 포트
RDS_PORT=3306
RDS_CRAWLER_DB=crawlerdb

# 세션 (운영 환경에서는 반드시 override)
SESSION_SECRET=change-me-in-production
